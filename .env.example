# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Slack Events API (App → Basic Information → Signing Secret)
SLACK_SIGNING_SECRET=

# Optional: bot token for thread replies (OAuth & Permissions → Bot User OAuth Token)
SLACK_BOT_TOKEN=

# Optional: only process messages in this channel (channel ID, e.g. C01234567)
SLACK_EXPENSE_CHANNEL_ID=
